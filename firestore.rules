rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 타자 줄 기록 (CPM 랭킹) — 현행 유지: 누구나 읽기, 검증된 생성만, 수정/삭제 금지
    match /records/{id} {
      allow read: if true;
      allow create: if
        request.resource.data.user is string
        && request.resource.data.user.size() >= 1
        && request.resource.data.user.size() <= 30
        && request.resource.data.cpm is number
        && request.resource.data.cpm >= 0
        && request.resource.data.cpm < 5000
        && request.resource.data.accuracy is number
        && request.resource.data.accuracy >= 0
        && request.resource.data.accuracy <= 1
        && request.resource.data.text is string
        && request.resource.data.text.size() >= 1
        && request.resource.data.text.size() <= 200
        && request.resource.data.at is number;
      allow update, delete: if false;
    }

    // 1분 스프린트 점수
    match /sprints/{id} {
      allow read: if true;
      allow create: if
        request.resource.data.user is string
        && request.resource.data.user.size() >= 1
        && request.resource.data.user.size() <= 30
        && request.resource.data.lang in ['ko', 'en']
        && request.resource.data.score is number
        && request.resource.data.score >= 0
        && request.resource.data.score <= 100000
        && request.resource.data.accuracy is number
        && request.resource.data.accuracy >= 0
        && request.resource.data.accuracy <= 1
        && request.resource.data.at is number;
      allow update, delete: if false;
    }

    // 낙하 게임 점수
    match /fallings/{id} {
      allow read: if true;
      allow create: if
        request.resource.data.user is string
        && request.resource.data.user.size() >= 1
        && request.resource.data.user.size() <= 30
        && request.resource.data.lang in ['ko', 'en']
        && request.resource.data.score is number
        && request.resource.data.score >= 0
        && request.resource.data.score <= 100000
        && request.resource.data.at is number;
      allow update, delete: if false;
    }
  }
}
